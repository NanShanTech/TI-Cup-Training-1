  <diagram name="数据处理任务流程图" id="adc_flow">
    <mxGraphModel dx="1086" dy="763" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="a_title" value="ADC/FFT/THD 数据处理流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="208" y="22" width="410" height="36" as="geometry" />
        </mxCell>

        <mxCell id="a_start" value="ADC_Proc()&#xa;每 10ms 被调度一次" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;arcSize=50;absoluteArcSize=1;fontFamily=Microsoft YaHei;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="270" y="88" width="190" height="62" as="geometry" />
        </mxCell>
        <mxCell id="a_check" value="ADC 采样是否完成?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="246" y="184" width="238" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a_wait" value="未完成则直接返回&#xa;等待下一次调度" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="560" y="208" width="170" height="64" as="geometry" />
        </mxCell>
        <mxCell id="a_clear" value="清除采样完成标志" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="264" y="328" width="202" height="56" as="geometry" />
        </mxCell>
        <mxCell id="a_prepare" value="fft_prepare()&#xa;将 ADC 采样值转换为 FFT 输入" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="232" y="414" width="266" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_window" value="fft_window()&#xa;加 Hanning 窗抑制频谱泄漏" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="232" y="514" width="266" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_fft" value="fft_process()&#xa;完成 FFT 计算并得到幅度谱" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="232" y="614" width="266" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_peak" value="fft_find_peaks() + fft_get_axis()&#xa;定位基波峰值与频率轴" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="222" y="714" width="286" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_harm" value="计算 1~5 次谐波能量&#xa;得到 2~5 次谐波占基波百分比" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="214" y="814" width="302" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_thd" value="THD_Compute()&#xa;计算总谐波失真 THD" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="248" y="914" width="234" height="64" as="geometry" />
        </mxCell>
        <mxCell id="a_save" value="更新 g_wave_info&#xa;保存 THD 和各次谐波占比" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="236" y="1008" width="258" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_restart" value="清空 ADC 缓冲区&#xa;重新启动 ADC_StartNormal()&#xa;开始下一轮 2048 点采样" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="226" y="1104" width="278" height="86" as="geometry" />
        </mxCell>

        <mxCell id="a_note" value="说明&#xa;&#xa;1. 采样缓冲区为 g_adc_buffer[2048]&#xa;2. 采样完成由 ADC DMA 中断置位标志&#xa;3. 数据处理与重新启动采样在任务中完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;dashed=1;fontFamily=Microsoft YaHei;fontSize=14;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="556" y="540" width="190" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a_yes" value="是" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="364" y="300" width="24" height="24" as="geometry" />
        </mxCell>
        <mxCell id="a_no" value="否" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="510" y="226" width="24" height="24" as="geometry" />
        </mxCell>

        <mxCell id="ae1" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_start" target="a_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae2" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="a_check" target="a_wait">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae3" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_check" target="a_clear">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae4" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_clear" target="a_prepare">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae5" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_prepare" target="a_window">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae6" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_window" target="a_fft">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae7" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_fft" target="a_peak">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae8" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_peak" target="a_harm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae9" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_harm" target="a_thd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae10" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_thd" target="a_save">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae11" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="a_save" target="a_restart">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="串口显示与命令解析流程图" id="uart_flow">
    <mxGraphModel dx="1086" dy="763" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="u_title" value="串口屏显示与命令解析流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="22" width="446" height="36" as="geometry" />
        </mxCell>

        <mxCell id="u_start" value="UART_Proc()&#xa;每 1s 被调度一次" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;arcSize=50;absoluteArcSize=1;fontFamily=Microsoft YaHei;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="278" y="86" width="180" height="62" as="geometry" />
        </mxCell>
        <mxCell id="u_thd" value="串口屏显示 THD 数值" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="258" y="178" width="220" height="56" as="geometry" />
        </mxCell>
        <mxCell id="u_mode" value="显示当前模式名称&#xa;例如无失真/削顶/交越/频谱模式" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="230" y="264" width="276" height="70" as="geometry" />
        </mxCell>
        <mxCell id="u_check" value="当前是否为频谱模式?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="247" y="366" width="242" height="110" as="geometry" />
        </mxCell>
        <mxCell id="u_skip" value="不是频谱模式&#xa;跳过频谱绘制" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="560" y="388" width="164" height="64" as="geometry" />
        </mxCell>
        <mxCell id="u_harm" value="显示 2~5 次谐波占比" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="256" y="514" width="224" height="56" as="geometry" />
        </mxCell>
        <mxCell id="u_bar" value="生成 300 字节柱状图数据&#xa;通过 addt 指令发送到串口屏" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="228" y="600" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="u_read" value="从环形缓冲区读取全部接收字节" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="232" y="704" width="272" height="56" as="geometry" />
        </mxCell>
        <mxCell id="u_parse" value="逐字节执行 Protocol_ParseByte()&#xa;进入双字节命令状态机" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="228" y="792" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="u_valid" value="命令是否有效?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="270" y="894" width="196" height="104" as="geometry" />
        </mxCell>
        <mxCell id="u_update" value="更新 g_mode / s_last_dist&#xa;切换显示或记住上次失真类型" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="224" y="1030" width="288" height="70" as="geometry" />
        </mxCell>
        <mxCell id="u_clear" value="清空残余接收数据后返回" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="1128" width="236" height="56" as="geometry" />
        </mxCell>

        <mxCell id="u_note_irq" value="串口接收背景流程&#xa;&#xa;UART 空闲中断触发后:&#xa;1. 从 RX FIFO 连续取字节&#xa;2. 写入环形缓冲区&#xa;3. 清除超时中断标志" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;dashed=1;fontFamily=Microsoft YaHei;fontSize=14;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
