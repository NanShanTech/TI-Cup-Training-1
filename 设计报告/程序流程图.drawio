<mxfile host="app.diagrams.net" modified="2026-07-07T05:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram name="主程序流程图" id="main_flow">
    <mxGraphModel dx="1086" dy="763" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t0" value="程序设计流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="263" y="20" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="主程序流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="220" height="30" as="geometry" />
        </mxCell>

        <mxCell id="m_start" value="开始" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;arcSize=50;absoluteArcSize=1;fontFamily=Microsoft YaHei;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="320" y="108" width="120" height="44" as="geometry" />
        </mxCell>
        <mxCell id="m_init1" value="BSP_Init()&#xa;完成系统时钟与外设底层初始化" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="180" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="m_init2" value="Serial_Init() 与 Serial_RxInit()&#xa;配置串口屏通信并开启 RX 空闲中断" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="235" y="278" width="290" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m_init3" value="SampleTimer_Init() + SampleTimer_SetRate()&#xa;配置定时器触发 ADC 采样" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="225" y="382" width="310" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m_init4" value="ADC_Init() + ADC_StartNormal(g_adc_buffer, FFT_N)&#xa;启动 2048 点 DMA 采样" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="215" y="486" width="330" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m_init5" value="Scheduler_Init()&#xa;注册 10ms 任务 ADC_Proc&#xa;注册 1s 任务 UART_Proc" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="235" y="592" width="290" height="92" as="geometry" />
        </mxCell>
        <mxCell id="m_loop" value="进入 while(1) 主循环&#xa;持续执行 Scheduler_Run()" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="255" y="716" width="250" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m_check" value="有到期任务?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="275" y="826" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="m_run" value="按调度周期调用任务&#xa;10ms: ADC_Proc()&#xa;1s: UART_Proc()" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="255" y="968" width="250" height="92" as="geometry" />
        </mxCell>

        <mxCell id="m_note_irq" value="后台中断流程&#xa;&#xa;1. SysTick_Handler: g_ms_tick 每 1ms 自增&#xa;2. ADC DMA 完成中断: 停止采样并置采样完成标志&#xa;3. UART 空闲中断: 读取 FIFO 字节并写入环形缓冲区" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;dashed=1;fontFamily=Microsoft YaHei;fontSize=14;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="555" y="218" width="220" height="170" as="geometry" />
        </mxCell>
        <mxCell id="m_note_sched" value="调度器依据 g_ms_tick 判断时间片&#xa;无任务到期则立即返回主循环&#xa;有任务到期则执行相应回调" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;dashed=1;fontFamily=Microsoft YaHei;fontSize=14;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="555" y="742" width="220" height="112" as="geometry" />
        </mxCell>
        <mxCell id="m_yes" value="是" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="384" y="944" width="24" height="24" as="geometry" />
        </mxCell>
        <mxCell id="m_no" value="否" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Microsoft YaHei;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="866" width="24" height="24" as="geometry" />
        </mxCell>

        <mxCell id="me1" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="m_start" target="m_init1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
